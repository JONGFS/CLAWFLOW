# ── Anthropic (required for CrewAI agents) ────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenAI (optional — enables TTS voiceover generation) ─────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Supabase (required for listing storage) ───────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co/
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── CrewAI (optional — defaults to anthropic/claude-sonnet-4-6) ───────────────
# CREWAI_MODEL=anthropic/claude-sonnet-4-6

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS (set this to your Vercel frontend before deploying) ─────────────────
CORS_ALLOW_ORIGINS=https://your-app.vercel.app
# CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$
